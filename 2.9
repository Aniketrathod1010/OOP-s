class Book {
    String title;
    String author;
    double price;

    Book(String title, String author, double price) {
        this.title = title;
        this.author = author;
        this.price = price;
    }

    void display() {
        System.out.println("Title: " + title);
        System.out.println("Author: " + author);
        System.out.println("Price: ₹" + price);
        System.out.println();
    }
}

public class Q19 {
    public static void main(String[] args) {
        Book[] books = new Book[3];

        books[0] = new Book("Java Programming", "James Gosling", 450);
        books[1] = new Book("Python Basics", "Guido van Rossum", 350);
        books[2] = new Book("Data Structures", "Mark Allen", 500);

        for (Book b : books) {
            b.display();
        }
    }
}
